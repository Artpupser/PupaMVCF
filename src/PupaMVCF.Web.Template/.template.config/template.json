{
  "$schema": "http://json.schemastore.org/template",
  "author": "Artpupser",
  "classifications": [
    "Web",
    "Framework",
    "MVC"
  ],
  "identity": "PupaMVCF.Web.Template",
  "name": "Simplify web template",
  "sourceName": "PupaMVCF.Web.Template",
  "shortName": "pupamvcf-web",
  "defaultName": "PupaMVCF.Web.App",
  "description": "Template for working with PupaMVCF.Framework",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "preferNameDirectory": true,
  "symbols": {
    "FrameworkVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "0.1.*",
      "replaces": "FrameworkVersion",
      "description": "Version of PupaMVCF.Framework"
    }
  }
}
{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },
  "StaticPrefix": "/api/public/files?name=",
  "Session": {
    "IdleTimeout": "24:00:00",
    "Expire": "24:00:00",
    "SameSite": 2,
    "Name": "CustomCookieName"
  },
  "Kestrel": {
    "Limits": {
      "MaxConcurrentConnections": 100,
      "MaxConcurrentUpgradedConnections": 100,
      "MaxRequestBodySize": 31457280,
      "MaxRequestBufferSize": 65536,
      "MaxRequestHeadersTotalSize": 32768,
      "MaxRequestLineSize": 8192,
      "RequestHeadersTimeout": "00:00:30",
      "KeepAliveTimeout": "00:02:00"
    }
  },
  "DatabaseString": "Host=;Port=;Database=;Username=;Password=",
  "DatabaseHost": "localhost",
  "DatabasePort": 50502,
  "DatabasePassword": "",
  "DatabaseUsername": "",
  "DatabaseName": "",
  "TimeoutClient": "00:00:10",
  "HttpsEnable": false,
  "Port": 50501,
  "Ip": "127.0.0.1",
  "Domain": "",
  "CaptchaSecureKey": "",
  "CaptchaSecureSite": ""
}

<Project>
    <ItemGroup>
        <Files Include="$(MSBuildThisFileDirectory)/../contentFiles/any/any/environment/**/*"/>
        <FilesProject Include="$(ProjectDir)/environment/**/*"/>
    </ItemGroup>
    <Target Name="InitEvn" BeforeTargets="PrepareForBuild">
        <MakeDir Directories="$(ProjectDir)environment"/>
        <MakeDir Directories="$(ProjectDir)environment/public"/>
        <Copy SourceFiles="@(Files)" DestinationFolder="$(ProjectDir)/environment/%(RecursiveDir)"/>
    </Target>

    <ItemGroup>
        <AppsettingsFile Include="$(MSBuildThisFileDirectory)/../contentFiles/any/any/appsettings.example.json"/>
    </ItemGroup>

    <Target Name="CopyAppsettingsExample" BeforeTargets="PrepareForBuild">
        <PropertyGroup>
            <AppsettingsTarget>$(ProjectDir)/appsettings.example.json</AppsettingsTarget>
        </PropertyGroup>

        <Copy SourceFiles="@(AppsettingsFile)"
              DestinationFiles="$(AppsettingsTarget)"
              Condition="!Exists('$(AppsettingsTarget)')"/>

    </Target>


    <Target Name="BuildEnv" AfterTargets="Build">
        <Copy SourceFiles="@(FilesProject)" DestinationFolder="$(TargetDir)/%(RecursiveDir)"/>
    </Target>
    <Target Name="PublishEnv" AfterTargets="Publish">
        <Copy SourceFiles="@(FilesProject)" DestinationFolder="$(PublishDir)/%(RecursiveDir)"/>
    </Target>
</Project>
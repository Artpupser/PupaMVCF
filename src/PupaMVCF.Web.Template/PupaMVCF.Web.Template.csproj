<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <PackageType>Template</PackageType>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <PackageId>PupaMVCF.Web.Template</PackageId>
        <Version>0.1.3</Version>
        <PackageTags>dotnet-new;template;web;mvс;pupamvcf</PackageTags>
        <IncludeContentInPack>true</IncludeContentInPack>
        <IncludeBuildOutput>false</IncludeBuildOutput>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <ContentTargetFolders>content</ContentTargetFolders>
        <TargetFramework>net8.0</TargetFramework>
        <Authors>Artpupser</Authors>
        <Owner>Artpupser</Owner>
        <OutputType>Exe</OutputType>
        <Company>Artpupser</Company>
        <EnableDefaultContentItems>false</EnableDefaultContentItems>
        <Description>Template for working with PupaMVCF.Framework</Description>
    </PropertyGroup>
    <ItemGroup>
        <Content Include="**\*" Exclude="bin\**;obj\**"/>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="PupaMVCF.Framework" Version="FrameworkVersion"/>
    </ItemGroup>
    <ItemGroup>
        <FilesProject Include="$(ProjectDir)/environment/**/*"/>
    </ItemGroup>
    <Target Name="BuildEnv" AfterTargets="Build">
        <Copy SourceFiles="@(FilesProject)" DestinationFolder="$(TargetDir)/%(RecursiveDir)"/>
    </Target>
    <Target Name="PublishEnv" AfterTargets="Publish">
        <Copy SourceFiles="@(FilesProject)" DestinationFolder="$(PublishDir)/%(RecursiveDir)"/>
    </Target>
</Project>
